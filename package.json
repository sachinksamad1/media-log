{
  "name": "media-log-monorepo",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=media-log-web",
    "dev:backend": "turbo dev --filter=media-log-backend",
    "build": "turbo build",
    "build:web": "turbo build --filter=media-log-web",
    "build:backend": "turbo build --filter=media-log-backend",
    "check": "turbo check",
    "lint": "turbo lint",
    "format": "turbo format",
    "test": "turbo test",
    "deploy": "pnpm deploy:backend && pnpm deploy:web",
    "deploy:web": "pnpm --filter media-log-web run build && pnpm exec firebase deploy --only hosting:web",
    "deploy:backend": "pnpm --filter media-log-backend run deploy",
    "clean": "rimraf apps/web/dist apps/backend/dist",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "firebase-tools": "^13.31.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "node-addon-api": "^8.3.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "turbo": "^2.9.6"
  },
  "lint-staged": {
    "apps/backend/**/*.{ts,js,mts,cjs}": [
      "eslint --config apps/backend/eslint.config.js --fix",
      "prettier --write"
    ],
    "apps/web/**/*.{ts,js,vue,mts,cjs}": [
      "eslint --config apps/web/eslint.config.js --fix",
      "prettier --write"
    ],
    "packages/shared-types/**/*.{ts,js,mts,cjs}": [
      "eslint --config packages/shared-types/eslint.config.js --fix",
      "prettier --write"
    ],
    "packages/shared-utils/**/*.{ts,js,mts,cjs}": [
      "eslint --config packages/shared-utils/eslint.config.js --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
